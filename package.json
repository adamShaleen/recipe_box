{
  "name": "recipe-box",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "packages/shared",
    "packages/infra",
    "packages/api",
    "packages/web"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "jest",
    "test:file": "jest --testPathPattern",
    "lint": "npm run lint --workspaces --if-present",
    "format:check": "npm run format:check --workspaces --if-present",
    "format": "npm run format --workspaces --if-present"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.1"
  }
}
